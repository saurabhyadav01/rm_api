{
  "info": {
    "_postman_id": "hellochotu-rm-app-collection",
    "name": "HelloChotu RM App API",
    "description": "HelloChotu RM App API\n\n**URL pattern:** `{{base_url}}/api/{{api_version}}/...`\n\nExample: `https://rmapi.hellochotu.com/api/v1/stores/onboard`\n\nVariables: `base_url`, `api_version`, `token`, `rm_id`, `store_id`, `phone`, `username`, `password`.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "https://rmapi.hellochotu.com" },
    { "key": "api_version", "value": "v1", "description": "Default API version (v1)" },
    { "key": "api_host", "value": "rmapi.hellochotu.com" },
    { "key": "local_base_url", "value": "http://localhost:4001" },
    { "key": "token", "value": "" },
    { "key": "rm_id", "value": "RM123" },
    { "key": "store_id", "value": "1" },
    { "key": "phone", "value": "9876543210" },
    { "key": "username", "value": "RM123" },
    { "key": "password", "value": "change-me" },
    { "key": "product_id", "value": "1" }
  ],
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{base_url}}/api/{{api_version}}/health",
            "description": "v1: https://rmapi.hellochotu.com/api/v1/health"
          }
        },
        {
          "name": "Health Check (legacy /api)",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{base_url}}/api/health",
            "description": "Unversioned alias — https://rmapi.hellochotu.com/api/health"
          }
        },
        {
          "name": "API Route Index",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{base_url}}/api/{{api_version}}",
            "description": "Lists all routes with full URLs for the current base_url"
          }
        }
      ]
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login (username + password)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (json?.data?.token) pm.collectionVariables.set('token', json.data.token);",
                  "if (json?.data?.user?.username) pm.collectionVariables.set('rm_id', json.data.user.username);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"{{username}}\",\n  \"password\": \"{{password}}\"\n}"
            },
            "url": "{{base_url}}/api/{{api_version}}/auth/login"
          }
        },
        {
          "name": "Send OTP",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"phone\": \"{{phone}}\",\n  \"role\": \"rm\"\n}"
            },
            "url": "{{base_url}}/api/{{api_version}}/auth/send-otp"
          }
        },
        {
          "name": "Verify OTP (login)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (json?.data?.token) pm.collectionVariables.set('token', json.data.token);",
                  "if (json?.data?.user?.username) pm.collectionVariables.set('rm_id', json.data.user.username);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"phone\": \"{{phone}}\",\n  \"otp\": \"123456\",\n  \"role\": \"rm\"\n}"
            },
            "url": "{{base_url}}/api/{{api_version}}/auth/verify-otp"
          }
        },
        {
          "name": "Request OTP (alias)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"phone\": \"{{phone}}\",\n  \"role\": \"rm\"\n}"
            },
            "url": "{{base_url}}/api/{{api_version}}/auth/request-otp"
          }
        },
        {
          "name": "Login OTP (alias)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"phone\": \"{{phone}}\",\n  \"otp\": \"123456\"\n}"
            },
            "url": "{{base_url}}/api/{{api_version}}/auth/login-otp"
          }
        },
        {
          "name": "Login Password (alias)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"{{username}}\",\n  \"password\": \"{{password}}\"\n}"
            },
            "url": "{{base_url}}/api/{{api_version}}/auth/login-password"
          }
        }
      ]
    },
    {
