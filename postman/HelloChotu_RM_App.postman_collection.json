            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"rm_id\": \"{{rm_id}}\",\n  \"page\": 1,\n  \"limit\": 10,\n  \"start_date\": \"\",\n  \"end_date\": \"\",\n  \"status\": \"\",\n  \"business_type\": \"\",\n  \"include_product_counts\": true\n}"
