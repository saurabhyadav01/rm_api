        {
          "name": "Stores List (GET)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/{{api_version}}/stores/list?rm_id={{rm_id}}&page=1&limit=10",
              "host": ["{{base_url}}"],
              "path": ["api", "{{api_version}}", "stores", "list"],
              "query": [
                { "key": "rm_id", "value": "{{rm_id}}" },
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "10" }
