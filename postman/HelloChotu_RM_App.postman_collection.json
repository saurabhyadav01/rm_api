{
  "info": {
    "_postman_id": "hellochotu-rm-app-collection",
    "name": "HelloChotu RM App API",
    "description": "HelloChotu RM App API — canonical routes only.\n\n**URL:** `{{base_url}}/api/{{api_version}}/...`\n\nVariables: `base_url`, `api_version`, `token`, `rm_id`, `store_id`, `phone`, `username`, `password`, `product_id`, `pincode`, `category_type_id`, `store_mobile`, `store_otp`.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "https://rmapi.hellochotu.com" },
    { "key": "api_version", "value": "v1" },
    { "key": "token", "value": "" },
    { "key": "rm_id", "value": "RM123" },
    { "key": "store_id", "value": "1" },
    { "key": "phone", "value": "9876543210" },
    { "key": "username", "value": "RM123" },
    { "key": "password", "value": "change-me" },
    { "key": "product_id", "value": "1" },
    { "key": "pincode", "value": "110001" },
    { "key": "category_type_id", "value": "3" },
    { "key": "store_mobile", "value": "9876543210" },
    { "key": "store_otp", "value": "123456" }
  ],
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{base_url}}/api/{{api_version}}/health"
          }
        },
        {
          "name": "API Route Index",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{base_url}}/api/{{api_version}}"
          }
        }
      ]
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login (username + password)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (json?.data?.token) pm.collectionVariables.set('token', json.data.token);",
                  "if (json?.data?.user?.username) pm.collectionVariables.set('rm_id', json.data.user.username);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"{{username}}\",\n  \"password\": \"{{password}}\"\n}"
            },
            "url": "{{base_url}}/api/{{api_version}}/auth/login"
          }
        },
        {
          "name": "Send OTP",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"phone\": \"{{phone}}\",\n  \"role\": \"rm\"\n}"
            },
            "url": "{{base_url}}/api/{{api_version}}/auth/send-otp"
          }
        },
        {
          "name": "Verify OTP (login)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (json?.data?.token) pm.collectionVariables.set('token', json.data.token);",
                  "if (json?.data?.user?.username) pm.collectionVariables.set('rm_id', json.data.user.username);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"phone\": \"{{phone}}\",\n  \"otp\": \"123456\",\n  \"role\": \"rm\"\n}"
            },
            "url": "{{base_url}}/api/{{api_version}}/auth/verify-otp"
          }
        }
      ]
    },
