PORT=4001
NODE_ENV=development

# Base URL (domain only, no /api path)
# Health: https://rmapi.hellochotu.com/api/v1/health
API_BASE_URL=https://rmapi.hellochotu.com
# If nginx only proxies /api to Node, set true so image_url uses /api/v1/uploads/...
# UPLOAD_SERVE_VIA_API=true
# Default: v1 (used when unset)
API_VERSION=v1
# Comma-separated origins, or * for local dev
CORS_ORIGIN=https://rmapi.hellochotu.com,http://localhost:3000,http://localhost:5173

MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DATABASE=hellochotu_main_db

# JWT secret for RM login tokens (required — login fails without this)
JWT_SECRET=change-me
# Alias accepted by rm_api if JWT_SECRET is unset:
# RM_JWT_SECRET=change-me

# Optional password login (RM must exist in relationship_managers with status=active)
RM_LOGIN_PASSWORD=change-me

# Production (hellchotunewapi): RM_SCHEMA_V2=true — uses hellochotu_microservices tables:
# stores, store_credentials, store_addresses, products, product_variants, …
# Does NOT use service_details or tbl_*.
# Local legacy DB only: RM_SCHEMA_V2=false
RM_SCHEMA_V2=true

# SMS (OTP) — same provider as HelloChotu auth service
SMS_BASE_URL=https://smsapi.edumarcsms.com/api/v1/sendsms
SMS_API_KEY=
SMS_SENDER_ID=HCHOTU
SMS_OTP_TEMPLATE_ID=1207176182760456483
# Optional: brand name in SMS template {name}
# CUSTOMER_HASH_KEY=
# Store onboarding welcome SMS (optional)
# SMS_ONBOARDING_TEMPLATE_ID=
# SMS_ONBOARDING_MESSAGE=Hello {name}, welcome to HelloChotu! Your onboarding fee is Rs {fee}. Thank you.
# Local dev only: allow send-otp without SMS (OTP stored in memory only)
# RM_ALLOW_OTP_WITHOUT_SMS=true

