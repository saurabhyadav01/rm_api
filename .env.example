PORT=4001
NODE_ENV=development

# Base URL (domain only, no /api path)
# Health: https://rmapi.hellochotu.com/api/v1/health
API_BASE_URL=https://rmapi.hellochotu.com
# Default: v1 (used when unset)
API_VERSION=v1
# Comma-separated origins, or * for local dev
CORS_ORIGIN=https://rmapi.hellochotu.com,http://localhost:3000,http://localhost:5173

MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DATABASE=hellochotu_main_db

# JWT secret for login tokens
JWT_SECRET=change-me

# Optional password login (RM must exist in relationship_managers with status=active)
RM_LOGIN_PASSWORD=change-me

# If your DB uses the new tables:
# stores, store_operating_hours, store_kyc, store_addresses
# products, product_variants, product_inventory, product_pricing
# Use hellochotu_microservices tables (products, product_variants, …). Set false for legacy tbl_* only.
RM_SCHEMA_V2=true

# SMS (OTP) — same provider as HelloChotu auth service
SMS_BASE_URL=https://smsapi.edumarcsms.com/api/v1/sendsms
SMS_API_KEY=
SMS_SENDER_ID=HCHOTU
SMS_OTP_TEMPLATE_ID=1207176182760456483
# Optional: brand name in SMS template {name}
# CUSTOMER_HASH_KEY=
# Local dev only: allow send-otp without SMS (OTP stored in memory only)
# RM_ALLOW_OTP_WITHOUT_SMS=true

