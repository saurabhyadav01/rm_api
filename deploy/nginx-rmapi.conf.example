# Example site config for https://rmapi.hellochotu.com (Ubuntu nginx)
# Copy/adapt to: /etc/nginx/sites-available/rmapi.hellochotu.com
# Then: sudo nginx -t && sudo systemctl reload nginx
#
# 413 "Request Entity Too Large" = increase client_max_body_size below.

server {
    listen 80;
    server_name rmapi.hellochotu.com;
    return 301 https://$host$request_uri;
}

server {
    listen 443 ssl http2;
    server_name rmapi.hellochotu.com;

    # REQUIRED for POST /api/v1/onboarding-image-upload (up to 10 MB files)
    client_max_body_size 10M;

    # Optional: slow mobile uploads
    client_body_timeout 120s;
    proxy_read_timeout 120s;
    proxy_send_timeout 120s;

    # ssl_certificate     /etc/letsencrypt/live/rmapi.hellochotu.com/fullchain.pem;
    # ssl_certificate_key /etc/letsencrypt/live/rmapi.hellochotu.com/privkey.pem;

    location / {
        proxy_pass http://127.0.0.1:4001;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }
}
